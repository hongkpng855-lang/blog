<svg xmlns="http://www.w3.org/2000/svg" width="512" height="512" viewBox="0 0 512 512">
  <defs>
    <linearGradient id="bg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#0a1628"/>
      <stop offset="100%" style="stop-color:#1a3a5c"/>
    </linearGradient>
    <linearGradient id="gold" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#ffd700"/>
      <stop offset="100%" style="stop-color:#ffaa00"/>
    </linearGradient>
    <filter id="glow">
      <feGaussianBlur stdDeviation="3" result="blur"/>
      <feMerge>
        <feMergeNode in="blur"/>
        <feMergeNode in="SourceGraphic"/>
      </feMerge>
    </filter>
  </defs>
  
  <!-- Background -->
  <rect width="512" height="512" fill="url(#bg)"/>
  
  <!-- Grid pattern -->
  <g stroke="#1a4a6a" stroke-width="1" fill="none" opacity="0.3">
    <line x1="0" y1="128" x2="512" y2="128"/>
    <line x1="0" y1="256" x2="512" y2="256"/>
    <line x1="0" y1="384" x2="512" y2="384"/>
    <line x1="128" y1="0" x2="128" y2="512"/>
    <line x1="256" y1="0" x2="256" y2="512"/>
    <line x1="384" y1="0" x2="384" y2="512"/>
  </g>
  
  <!-- Rising chart bars -->
  <g fill="url(#gold)" filter="url(#glow)">
    <rect x="100" y="350" width="50" height="100" rx="4"/>
    <rect x="180" y="280" width="50" height="170" rx="4"/>
    <rect x="260" y="220" width="50" height="230" rx="4"/>
    <rect x="340" y="150" width="50" height="300" rx="4"/>
    <rect x="420" y="100" width="50" height="350" rx="4"/>
  </g>
  
  <!-- Upward arrow -->
  <g fill="none" stroke="#ffd700" stroke-width="4" filter="url(#glow)">
    <path d="M80 380 L200 300 L320 220 L440 120"/>
    <polygon points="440,120 425,135 455,135" fill="#ffd700"/>
  </g>
  
  <!-- Coin stack -->
  <g>
    <ellipse cx="150" cy="420" rx="40" ry="15" fill="#ffd700" stroke="#ffaa00" stroke-width="2"/>
    <ellipse cx="150" cy="400" rx="40" ry="15" fill="#ffd700" stroke="#ffaa00" stroke-width="2"/>
    <ellipse cx="150" cy="380" rx="40" ry="15" fill="#ffd700" stroke="#ffaa00" stroke-width="2"/>
    <text x="150" y="450" text-anchor="middle" fill="#ffd700" font-family="Arial" font-size="16" font-weight="bold">$</text>
  </g>
  
  <!-- Calendar icon (monthly investment) -->
  <g transform="translate(350, 350)">
    <rect x="0" y="0" width="80" height="80" rx="8" fill="#0a1628" stroke="#ffd700" stroke-width="2"/>
    <rect x="0" y="0" width="80" height="20" rx="8" fill="#ffd700"/>
    <text x="40" y="55" text-anchor="middle" fill="#ffd700" font-family="Arial" font-size="28" font-weight="bold">29</text>
  </g>
  
  <!-- Title -->
  <text x="256" y="60" text-anchor="middle" fill="#ffd700" font-family="Arial, sans-serif" font-size="28" font-weight="bold" filter="url(#glow)">ETF 投資策略</text>
  
  <!-- Subtitle -->
  <text x="256" y="485" text-anchor="middle" fill="#88ccff" font-family="Arial, sans-serif" font-size="18">定期定額 vs 單筆投資</text>
</svg>
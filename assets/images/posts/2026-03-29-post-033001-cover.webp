<svg xmlns="http://www.w3.org/2000/svg" width="512" height="512" viewBox="0 0 512 512">
  <defs>
    <linearGradient id="bg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#0d1b2a"/>
      <stop offset="100%" style="stop-color:#1b3a5c"/>
    </linearGradient>
    <linearGradient id="gold" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#ffd700"/>
      <stop offset="100%" style="stop-color:#ffaa00"/>
    </linearGradient>
    <linearGradient id="navy" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#1a3a5c"/>
      <stop offset="100%" style="stop-color:#0d1b2a"/>
    </linearGradient>
    <filter id="glow">
      <feGaussianBlur stdDeviation="2" result="blur"/>
      <feMerge>
        <feMergeNode in="blur"/>
        <feMergeNode in="SourceGraphic"/>
      </feMerge>
    </filter>
  </defs>
  
  <!-- Background -->
  <rect width="512" height="512" fill="url(#bg)"/>
  
  <!-- Grid pattern -->
  <g stroke="#1a4a6a" stroke-width="0.5" opacity="0.3">
    <line x1="0" y1="128" x2="512" y2="128"/>
    <line x1="0" y1="256" x2="512" y2="256"/>
    <line x1="0" y1="384" x2="512" y2="384"/>
    <line x1="128" y1="0" x2="128" y2="512"/>
    <line x1="256" y1="0" x2="256" y2="512"/>
    <line x1="384" y1="0" x2="384" y2="512"/>
  </g>
  
  <!-- Growth chart -->
  <polyline points="60,350 120,320 180,280 240,250 300,200 360,180 420,140 480,100" 
            fill="none" stroke="url(#gold)" stroke-width="4" filter="url(#glow)"/>
  
  <!-- Data points -->
  <g fill="#ffd700" filter="url(#glow)">
    <circle cx="60" cy="350" r="6"/>
    <circle cx="120" cy="320" r="6"/>
    <circle cx="180" cy="280" r="6"/>
    <circle cx="240" cy="250" r="6"/>
    <circle cx="300" cy="200" r="6"/>
    <circle cx="360" cy="180" r="6"/>
    <circle cx="420" cy="140" r="6"/>
    <circle cx="480" cy="100" r="8"/>
  </g>
  
  <!-- Bar chart -->
  <g fill="#1a5a7a" opacity="0.6">
    <rect x="80" y="380" width="40" height="80" rx="4"/>
    <rect x="140" y="350" width="40" height="110" rx="4"/>
    <rect x="200" y="320" width="40" height="140" rx="4"/>
    <rect x="260" y="290" width="40" height="170" rx="4"/>
    <rect x="320" y="260" width="40" height="200" rx="4"/>
    <rect x="380" y="230" width="40" height="230" rx="4"/>
    <rect x="440" y="200" width="40" height="260" rx="4"/>
  </g>
  
  <!-- Coin stack -->
  <g transform="translate(80, 100)">
    <ellipse cx="30" cy="60" rx="30" ry="10" fill="#ffd700" opacity="0.3"/>
    <ellipse cx="30" cy="45" rx="30" ry="10" fill="#ffd700" opacity="0.5"/>
    <ellipse cx="30" cy="30" rx="30" ry="10" fill="#ffd700" opacity="0.7"/>
    <ellipse cx="30" cy="15" rx="30" ry="10" fill="#ffd700"/>
    <text x="30" y="20" text-anchor="middle" fill="#0d1b2a" font-size="12" font-weight="bold">$</text>
  </g>
  
  <!-- Pie chart -->
  <g transform="translate(400, 400)">
    <circle cx="0" cy="0" r="50" fill="none" stroke="#1a5a7a" stroke-width="30" stroke-dasharray="80 220" opacity="0.6"/>
    <circle cx="0" cy="0" r="50" fill="none" stroke="#ffd700" stroke-width="30" stroke-dasharray="60 250" stroke-dashoffset="-80" opacity="0.8"/>
    <circle cx="0" cy="0" r="50" fill="none" stroke="#00f5ff" stroke-width="30" stroke-dasharray="50 260" stroke-dashoffset="-140"/>
    <circle cx="0" cy="0" r="25" fill="#0d1b2a"/>
  </g>
  
  <!-- Title -->
  <text x="256" y="480" text-anchor="middle" fill="#ffd700" font-family="Arial, sans-serif" font-size="24" font-weight="bold" filter="url(#glow)">基金投資</text>
  
  <!-- Decorative elements -->
  <g fill="#ffd700" opacity="0.2">
    <circle cx="50" cy="50" r="20"/>
    <circle cx="460" cy="50" r="15"/>
    <circle cx="50" cy="460" r="15"/>
  </g>
</svg>
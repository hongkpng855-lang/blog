<svg xmlns="http://www.w3.org/2000/svg" width="512" height="512" viewBox="0 0 512 512">
  <defs>
    <linearGradient id="bg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#0a1628"/>
      <stop offset="100%" style="stop-color:#1a2a4a"/>
    </linearGradient>
    <linearGradient id="gold" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#ffd700"/>
      <stop offset="100%" style="stop-color:#ffb347"/>
    </linearGradient>
    <linearGradient id="green" x1="0%" y1="100%" x2="0%" y2="0%">
      <stop offset="0%" style="stop-color:#00c853"/>
      <stop offset="100%" style="stop-color:#69f0ae"/>
    </linearGradient>
    <filter id="glow">
      <feGaussianBlur stdDeviation="2" result="blur"/>
      <feMerge>
        <feMergeNode in="blur"/>
        <feMergeNode in="SourceGraphic"/>
      </feMerge>
    </filter>
  </defs>
  
  <!-- Background -->
  <rect width="512" height="512" fill="url(#bg)"/>
  
  <!-- Grid lines -->
  <g stroke="#1a3a5a" stroke-width="1" opacity="0.3">
    <line x1="50" y1="380" x2="462" y2="380"/>
    <line x1="50" y1="310" x2="462" y2="310"/>
    <line x1="50" y1="240" x2="462" y2="240"/>
    <line x1="50" y1="170" x2="462" y2="170"/>
    <line x1="50" y1="100" x2="462" y2="100"/>
  </g>
  
  <!-- Candlestick chart -->
  <g filter="url(#glow)">
    <!-- Green candles -->
    <rect x="70" y="280" width="25" height="60" fill="url(#green)" rx="2"/>
    <line x1="82" y1="270" x2="82" y2="350" stroke="#69f0ae" stroke-width="2"/>
    
    <rect x="130" y="250" width="25" height="50" fill="url(#green)" rx="2"/>
    <line x1="142" y1="240" x2="142" y2="310" stroke="#69f0ae" stroke-width="2"/>
    
    <rect x="190" y="220" width="25" height="55" fill="url(#green)" rx="2"/>
    <line x1="202" y1="210" x2="202" y2="290" stroke="#69f0ae" stroke-width="2"/>
    
    <!-- Red candle -->
    <rect x="250" y="180" width="25" height="45" fill="#ff5252" rx="2"/>
    <line x1="262" y1="170" x2="262" y2="240" stroke="#ff8a80" stroke-width="2"/>
    
    <!-- Green candles -->
    <rect x="310" y="150" width="25" height="50" fill="url(#green)" rx="2"/>
    <line x1="322" y1="140" x2="322" y2="210" stroke="#69f0ae" stroke-width="2"/>
    
    <rect x="370" y="120" width="25" height="55" fill="url(#green)" rx="2"/>
    <line x1="382" y1="100" x2="382" y2="190" stroke="#69f0ae" stroke-width="2"/>
    
    <rect x="430" y="80" width="25" height="60" fill="url(#green)" rx="2"/>
    <line x1="442" y1="70" x2="442" y2="160" stroke="#69f0ae" stroke-width="2"/>
  </g>
  
  <!-- Moving average line -->
  <path d="M80 320 Q150 280 200 250 T300 200 T400 140 T460 100" 
        fill="none" stroke="url(#gold)" stroke-width="3" filter="url(#glow)"/>
  
  <!-- Magnifying glass with chart -->
  <g transform="translate(100, 400)">
    <circle cx="0" cy="0" r="35" fill="none" stroke="url(#gold)" stroke-width="3" filter="url(#glow)"/>
    <line x1="25" y1="25" x2="50" y2="50" stroke="url(#gold)" stroke-width="4" stroke-linecap="round"/>
    <!-- Mini chart inside -->
    <polyline points="-20,10 -10,-5 0,5 10,-10 20,0" fill="none" stroke="#69f0ae" stroke-width="2"/>
  </g>
  
  <!-- Dollar sign -->
  <text x="380" y="440" fill="url(#gold)" font-family="Arial, sans-serif" font-size="48" font-weight="bold" filter="url(#glow)">$</text>
  
  <!-- Title -->
  <text x="256" y="50" text-anchor="middle" fill="url(#gold)" font-family="Arial, sans-serif" font-size="22" font-weight="bold" filter="url(#glow)">股票分析基礎</text>
  
  <!-- Labels -->
  <text x="50" y="400" fill="#6b8299" font-family="Arial, sans-serif" font-size="10">基本面</text>
  <text x="420" y="400" fill="#6b8299" font-family="Arial, sans-serif" font-size="10">技術面</text>
</svg>
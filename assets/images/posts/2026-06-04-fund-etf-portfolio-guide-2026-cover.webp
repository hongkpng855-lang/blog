<svg xmlns="http://www.w3.org/2000/svg" width="512" height="512" viewBox="0 0 512 512">
  <defs>
    <linearGradient id="bg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#1B2A4A"/>
      <stop offset="100%" style="stop-color:#0F1A2E"/>
    </linearGradient>
    <linearGradient id="gold" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#C9A84C"/>
      <stop offset="100%" style="stop-color:#D4AF37"/>
    </linearGradient>
  </defs>
  <rect width="512" height="512" fill="url(#bg)"/>
  <!-- Scale beam -->
  <line x1="80" y1="180" x2="432" y2="180" stroke="#C9A84C" stroke-width="3"/>
  <!-- Fulcrum triangle -->
  <polygon points="256,180 236,260 276,260" fill="#C9A84C" opacity="0.8"/>
  <!-- Left pan: ETF -->
  <circle cx="160" cy="260" r="48" fill="none" stroke="#4A90D9" stroke-width="2.5"/>
  <text x="160" y="252" text-anchor="middle" fill="#4A90D9" font-family="Arial" font-size="22" font-weight="bold">ETF</text>
  <text x="160" y="274" text-anchor="middle" fill="#8899BB" font-family="Arial" font-size="11">追蹤指數</text>
  <!-- Right pan: Fund -->
  <circle cx="352" cy="260" r="48" fill="none" stroke="#C9A84C" stroke-width="2.5"/>
  <text x="352" y="252" text-anchor="middle" fill="#C9A84C" font-family="Arial" font-size="22" font-weight="bold">基金</text>
  <text x="352" y="274" text-anchor="middle" fill="#8899BB" font-family="Arial" font-size="11">主動管理</text>
  <!-- Equal sign -->
  <text x="256" y="210" text-anchor="middle" fill="#C9A84C" font-family="Arial" font-size="14">⚖️</text>
  <!-- Bottom title -->
  <text x="256" y="340" text-anchor="middle" fill="#C9A84C" font-family="Arial" font-size="18" font-weight="bold">核心＋衛星配置</text>
  <text x="256" y="368" text-anchor="middle" fill="#8899BB" font-family="Arial" font-size="12">ETF 打底 · 基金創造超額報酬</text>
  <!-- Decorative bars -->
  <rect x="180" y="400" width="152" height="3" rx="1.5" fill="#C9A84C" opacity="0.4"/>
  <rect x="200" y="410" width="112" height="2" rx="1" fill="#C9A84C" opacity="0.2"/>
  <!-- Chart line decoration -->
  <polyline points="100,450 140,420 180,440 220,410 260,430 300,390 340,410 380,380 412,395"
    fill="none" stroke="#4A90D9" stroke-width="1.5" opacity="0.3"/>
</svg>

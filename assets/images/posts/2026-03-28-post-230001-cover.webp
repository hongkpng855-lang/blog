<svg xmlns="http://www.w3.org/2000/svg" width="512" height="512" viewBox="0 0 512 512">
  <defs>
    <linearGradient id="bg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#1a472a"/>
      <stop offset="100%" style="stop-color:#2d5a3d"/>
    </linearGradient>
    <linearGradient id="heart" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#7ec8a3"/>
      <stop offset="100%" style="stop-color:#3d9970"/>
    </linearGradient>
    <linearGradient id="lotus" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#b8e6d4"/>
      <stop offset="100%" style="stop-color:#7ec8a3"/>
    </linearGradient>
    <filter id="glow">
      <feGaussianBlur stdDeviation="3" result="blur"/>
      <feMerge>
        <feMergeNode in="blur"/>
        <feMergeNode in="SourceGraphic"/>
      </feMerge>
    </filter>
  </defs>
  
  <!-- Background -->
  <rect width="512" height="512" fill="url(#bg)"/>
  
  <!-- Circular border -->
  <circle cx="256" cy="256" r="200" fill="none" stroke="#7ec8a3" stroke-width="3" opacity="0.3"/>
  <circle cx="256" cy="256" r="180" fill="none" stroke="#b8e6d4" stroke-width="2" opacity="0.2"/>
  
  <!-- Lotus flower petals -->
  <g filter="url(#glow)">
    <!-- Center petal -->
    <ellipse cx="256" cy="200" rx="30" ry="50" fill="url(#lotus)" transform="rotate(0 256 256)"/>
    <!-- Left petals -->
    <ellipse cx="256" cy="200" rx="30" ry="50" fill="url(#lotus)" opacity="0.9" transform="rotate(-30 256 256)"/>
    <ellipse cx="256" cy="200" rx="30" ry="50" fill="url(#lotus)" opacity="0.8" transform="rotate(-60 256 256)"/>
    <!-- Right petals -->
    <ellipse cx="256" cy="200" rx="30" ry="50" fill="url(#lotus)" opacity="0.9" transform="rotate(30 256 256)"/>
    <ellipse cx="256" cy="200" rx="30" ry="50" fill="url(#lotus)" opacity="0.8" transform="rotate(60 256 256)"/>
  </g>
  
  <!-- Brain/Heart symbol -->
  <path d="M256 320 
           C256 320, 220 290, 220 260 
           C220 240, 238 225, 256 240
           C274 225, 292 240, 292 260
           C292 290, 256 320, 256 320 Z" 
        fill="url(#heart)" filter="url(#glow)"/>
  
  <!-- Inner glow -->
  <circle cx="256" cy="280" r="20" fill="#fff" opacity="0.3" filter="url(#glow)"/>
  
  <!-- Floating leaves -->
  <g fill="#7ec8a3" opacity="0.4">
    <ellipse cx="80" cy="100" rx="15" ry="8" transform="rotate(-20 80 100)"/>
    <ellipse cx="420" cy="380" rx="15" ry="8" transform="rotate(30 420 380)"/>
    <ellipse cx="100" cy="400" rx="12" ry="6" transform="rotate(-45 100 400)"/>
    <ellipse cx="400" cy="120" rx="12" ry="6" transform="rotate(15 400 120)"/>
  </g>
  
  <!-- Title -->
  <text x="256" y="480" text-anchor="middle" fill="#b8e6d4" font-family="Arial, sans-serif" font-size="28" font-weight="bold">心理健康</text>
</svg>
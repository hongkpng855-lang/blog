<svg xmlns="http://www.w3.org/2000/svg" width="512" height="512" viewBox="0 0 512 512">
  <defs>
    <linearGradient id="bg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#0a1a2e"/>
      <stop offset="100%" style="stop-color:#1a3a5c"/>
    </linearGradient>
    <linearGradient id="gold" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#ffd700"/>
      <stop offset="100%" style="stop-color:#ffaa00"/>
    </linearGradient>
    <linearGradient id="growth" x1="0%" y1="100%" x2="0%" y2="0%">
      <stop offset="0%" style="stop-color:#00aa55"/>
      <stop offset="100%" style="stop-color:#00ff88"/>
    </linearGradient>
    <filter id="glow">
      <feGaussianBlur stdDeviation="2" result="blur"/>
      <feMerge>
        <feMergeNode in="blur"/>
        <feMergeNode in="SourceGraphic"/>
      </feMerge>
    </filter>
  </defs>
  
  <!-- Background -->
  <rect width="512" height="512" fill="url(#bg)"/>
  
  <!-- Grid lines -->
  <g stroke="#1a4a6a" stroke-width="0.5" opacity="0.3">
    <line x1="50" y1="400" x2="462" y2="400"/>
    <line x1="50" y1="320" x2="462" y2="320"/>
    <line x1="50" y1="240" x2="462" y2="240"/>
    <line x1="50" y1="160" x2="462" y2="160"/>
  </g>
  
  <!-- Growth chart -->
  <path d="M80 380 Q150 350 200 300 T320 200 T420 120" 
        fill="none" stroke="url(#growth)" stroke-width="4" filter="url(#glow)"/>
  
  <!-- Data points -->
  <circle cx="80" cy="380" r="8" fill="#00ff88" filter="url(#glow)"/>
  <circle cx="200" cy="300" r="8" fill="#00dd77" filter="url(#glow)"/>
  <circle cx="320" cy="200" r="8" fill="#00bb66" filter="url(#glow)"/>
  <circle cx="420" cy="120" r="8" fill="#00aa55" filter="url(#glow)"/>
  
  <!-- Coins stack -->
  <g transform="translate(100, 420)">
    <ellipse cx="0" cy="0" rx="30" ry="10" fill="url(#gold)" opacity="0.9"/>
    <ellipse cx="0" cy="-15" rx="30" ry="10" fill="url(#gold)" opacity="0.9"/>
    <ellipse cx="0" cy="-30" rx="30" ry="10" fill="url(#gold)" opacity="0.9"/>
    <ellipse cx="0" cy="-45" rx="30" ry="10" fill="url(#gold)" opacity="0.9"/>
  </g>
  
  <!-- Arrow up -->
  <g transform="translate(420, 80)">
    <polygon points="0,-20 15,10 -15,10" fill="url(#growth)" filter="url(#glow)"/>
    <rect x="-6" y="10" width="12" height="30" fill="url(#growth)" filter="url(#glow)"/>
  </g>
  
  <!-- Dollar sign -->
  <g transform="translate(256, 80)" filter="url(#glow)">
    <circle cx="0" cy="0" r="35" fill="none" stroke="url(#gold)" stroke-width="3"/>
    <text x="0" y="12" text-anchor="middle" fill="url(#gold)" font-family="Arial" font-size="40" font-weight="bold">$</text>
  </g>
  
  <!-- Title -->
  <text x="256" y="470" text-anchor="middle" fill="url(#gold)" font-family="Arial, sans-serif" font-size="28" font-weight="bold" filter="url(#glow)">投資入門</text>
  
  <!-- Subtitle -->
  <text x="256" y="495" text-anchor="middle" fill="#88ccaa" font-family="Arial, sans-serif" font-size="14">Investment Guide</text>
</svg>
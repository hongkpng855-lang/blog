<svg xmlns="http://www.w3.org/2000/svg" width="512" height="512" viewBox="0 0 512 512">
  <defs>
    <linearGradient id="sky" x1="0%" y1="0%" x2="0%" y2="100%">
      <stop offset="0%" style="stop-color:#87CEEB"/>
      <stop offset="60%" style="stop-color:#E0F4FF"/>
      <stop offset="100%" style="stop-color:#FFF5E6"/>
    </linearGradient>
    <linearGradient id="mountain" x1="0%" y1="0%" x2="0%" y2="100%">
      <stop offset="0%" style="stop-color:#4A90A4"/>
      <stop offset="100%" style="stop-color:#2D5A6B"/>
    </linearGradient>
    <linearGradient id="sun" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#FFD700"/>
      <stop offset="100%" style="stop-color:#FFA500"/>
    </linearGradient>
  </defs>
  
  <!-- Background sky -->
  <rect width="512" height="512" fill="url(#sky)"/>
  
  <!-- Sun -->
  <circle cx="420" cy="100" r="50" fill="url(#sun)" opacity="0.9"/>
  
  <!-- Clouds -->
  <g fill="white" opacity="0.8">
    <ellipse cx="120" cy="80" rx="50" ry="25"/>
    <ellipse cx="160" cy="70" rx="40" ry="20"/>
    <ellipse cx="80" cy="75" rx="35" ry="18"/>
    
    <ellipse cx="350" cy="150" rx="45" ry="22"/>
    <ellipse cx="390" cy="145" rx="35" ry="18"/>
  </g>
  
  <!-- Mountains -->
  <polygon points="0,350 150,180 300,350" fill="url(#mountain)"/>
  <polygon points="100,350 280,150 460,350" fill="#5BA3B8" opacity="0.9"/>
  <polygon points="200,350 400,200 512,300 512,350" fill="#6BB5C9"/>
  
  <!-- Snow caps -->
  <polygon points="150,180 130,210 170,210" fill="white" opacity="0.9"/>
  <polygon points="280,150 255,185 305,185" fill="white" opacity="0.9"/>
  
  <!-- Airplane -->
  <g transform="translate(80, 120) rotate(-10)">
    <ellipse cx="0" cy="0" rx="35" ry="8" fill="white" stroke="#ddd" stroke-width="1"/>
    <polygon points="-35,0 -50,-5 -50,5" fill="#3B82C4"/>
    <polygon points="25,0 40,-15 40,15" fill="white" stroke="#ddd" stroke-width="1"/>
    <polygon points="-20,0 -25,-8 -15,-8" fill="white"/>
  </g>
  
  <!-- Suitcase -->
  <g transform="translate(256, 380)">
    <rect x="-40" y="-30" width="80" height="60" rx="5" fill="#E07B39" stroke="#C46830" stroke-width="2"/>
    <rect x="-15" y="-35" width="30" height="8" rx="3" fill="#C46830"/>
    <line x1="-40" y1="-10" x2="40" y2="-10" stroke="#C46830" stroke-width="2"/>
    <circle cx="-25" cy="35" r="6" fill="#333"/>
    <circle cx="25" cy="35" r="6" fill="#333"/>
  </g>
  
  <!-- Map/Pin -->
  <g transform="translate(380, 400)">
    <path d="M0,-40 C-15,-40 -25,-25 -25,-10 C-25,5 0,30 0,30 C0,30 25,5 25,-10 C25,-25 15,-40 0,-40" fill="#E74C3C"/>
    <circle cx="0" cy="-15" r="8" fill="white"/>
  </g>
  
  <!-- Compass -->
  <g transform="translate(130, 400)">
    <circle cx="0" cy="0" r="30" fill="white" stroke="#D4A84B" stroke-width="3"/>
    <circle cx="0" cy="0" r="22" fill="none" stroke="#ddd" stroke-width="1"/>
    <polygon points="0,-18 5,0 0,8 -5,0" fill="#E74C3C"/>
    <polygon points="0,18 5,0 0,-8 -5,0" fill="#333"/>
    <text x="0" y="-8" text-anchor="middle" fill="white" font-size="8" font-weight="bold">N</text>
  </g>
  
  <!-- Title -->
  <text x="256" y="480" text-anchor="middle" fill="#2D5A6B" font-family="Arial, sans-serif" font-size="28" font-weight="bold">旅行規劃</text>
  
  <!-- Decorative elements -->
  <circle cx="50" cy="300" r="3" fill="#FFD700" opacity="0.6"/>
  <circle cx="480" cy="280" r="3" fill="#FFD700" opacity="0.6"/>
  <circle cx="200" cy="250" r="2" fill="#FFD700" opacity="0.4"/>
</svg>
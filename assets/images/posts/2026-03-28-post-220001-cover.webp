<svg xmlns="http://www.w3.org/2000/svg" width="512" height="512" viewBox="0 0 512 512">
  <defs>
    <linearGradient id="bg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#1a472a"/>
      <stop offset="100%" style="stop-color:#2d5a3d"/>
    </linearGradient>
    <linearGradient id="accent" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#7ed957"/>
      <stop offset="100%" style="stop-color:#4ade80"/>
    </linearGradient>
    <filter id="glow">
      <feGaussianBlur stdDeviation="2" result="blur"/>
      <feMerge>
        <feMergeNode in="blur"/>
        <feMergeNode in="SourceGraphic"/>
      </feMerge>
    </filter>
  </defs>
  
  <!-- Background -->
  <rect width="512" height="512" fill="url(#bg)"/>
  
  <!-- Decorative circles -->
  <circle cx="100" cy="100" r="80" fill="#2d5a3d" opacity="0.3"/>
  <circle cx="420" cy="400" r="100" fill="#2d5a3d" opacity="0.3"/>
  
  <!-- Dumbbell icon -->
  <g transform="translate(256, 200)" filter="url(#glow)">
    <!-- Left weight -->
    <rect x="-120" y="-25" width="30" height="50" rx="5" fill="url(#accent)"/>
    <rect x="-110" y="-35" width="10" height="70" rx="3" fill="url(#accent)"/>
    <!-- Bar -->
    <rect x="-90" y="-8" width="180" height="16" rx="4" fill="#c4b5a0"/>
    <!-- Right weight -->
    <rect x="90" y="-25" width="30" height="50" rx="5" fill="url(#accent)"/>
    <rect x="100" y="-35" width="10" height="70" rx="3" fill="url(#accent)"/>
  </g>
  
  <!-- Heart/pulse line -->
  <path d="M50 320 L150 320 L170 280 L190 360 L210 300 L230 320 L460 320" 
        fill="none" stroke="url(#accent)" stroke-width="3" filter="url(#glow)"/>
  
  <!-- Running figure silhouette -->
  <g transform="translate(256, 400)" fill="url(#accent)" filter="url(#glow)">
    <!-- Head -->
    <circle cx="0" cy="-70" r="20"/>
    <!-- Body -->
    <ellipse cx="0" cy="-30" rx="15" ry="30"/>
    <!-- Arms -->
    <line x1="-25" y1="-40" x2="-40" y2="-20" stroke="url(#accent)" stroke-width="8" stroke-linecap="round"/>
    <line x1="25" y1="-40" x2="40" y2="-20" stroke="url(#accent)" stroke-width="8" stroke-linecap="round"/>
    <!-- Legs -->
    <line x1="-10" y1="0" x2="-30" y2="40" stroke="url(#accent)" stroke-width="8" stroke-linecap="round"/>
    <line x1="10" y1="0" x2="30" y2="40" stroke="url(#accent)" stroke-width="8" stroke-linecap="round"/>
  </g>
  
  <!-- Leaf decorations -->
  <g fill="#7ed957" opacity="0.6">
    <ellipse cx="50" cy="450" rx="20" ry="10" transform="rotate(-30 50 450)"/>
    <ellipse cx="460" cy="80" rx="25" ry="12" transform="rotate(20 460 80)"/>
  </g>
  
  <!-- Title -->
  <text x="256" y="480" text-anchor="middle" fill="url(#accent)" font-family="Arial, sans-serif" font-size="28" font-weight="bold" filter="url(#glow)">健康運動</text>
</svg>
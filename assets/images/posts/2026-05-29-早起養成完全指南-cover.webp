<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512" width="512" height="512">
  <defs>
    <linearGradient id="sky" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#FFD700" stop-opacity="0.9"/>
      <stop offset="40%" stop-color="#FFA500" stop-opacity="0.7"/>
      <stop offset="70%" stop-color="#87CEEB" stop-opacity="0.5"/>
      <stop offset="100%" stop-color="#E0F7FA" stop-opacity="0.4"/>
    </linearGradient>
    <linearGradient id="sunbeam" x1="0.5" y1="0" x2="0.5" y2="1">
      <stop offset="0%" stop-color="#FFF8E1" stop-opacity="0.6"/>
      <stop offset="100%" stop-color="#FFF8E1" stop-opacity="0"/>
    </linearGradient>
    <linearGradient id="floor" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#8B7355" stop-opacity="0.3"/>
      <stop offset="100%" stop-color="#6B5B45" stop-opacity="0.5"/>
    </linearGradient>
    <radialGradient id="sunGlow" cx="0.5" cy="0.15" r="0.3">
      <stop offset="0%" stop-color="#FFD700" stop-opacity="0.4"/>
      <stop offset="100%" stop-color="#FFD700" stop-opacity="0"/>
    </radialGradient>
  </defs>

  <!-- Background sky -->
  <rect width="512" height="512" fill="url(#sky)"/>

  <!-- Sun glow -->
  <circle cx="256" cy="80" r="120" fill="url(#sunGlow)"/>

  <!-- Sun -->
  <circle cx="256" cy="70" r="40" fill="#FFD700" opacity="0.9"/>
  <circle cx="256" cy="70" r="35" fill="#FFF176"/>

  <!-- Sun rays -->
  <g stroke="#FFD700" stroke-width="3" opacity="0.5" stroke-linecap="round">
    <line x1="256" y1="20" x2="256" y2="5"/>
    <line x1="296" y1="40" x2="310" y2="28"/>
    <line x1="310" y1="70" x2="325" y2="70"/>
    <line x1="296" y1="100" x2="310" y2="112"/>
    <line x1="256" y1="120" x2="256" y2="135"/>
    <line x1="216" y1="100" x2="202" y2="112"/>
    <line x1="202" y1="70" x2="187" y2="70"/>
    <line x1="216" y1="40" x2="202" y2="28"/>
  </g>

  <!-- Sunbeams streaming down -->
  <polygon points="220,110 160,512 352,512 290,110" fill="url(#sunbeam)" opacity="0.4"/>

  <!-- Window frame -->
  <rect x="80" y="100" width="150" height="200" rx="4" fill="#5D4037" opacity="0.8"/>
  <rect x="90" y="110" width="130" height="180" fill="#B3E5FC" opacity="0.3"/>
  <!-- Window cross -->
  <line x1="155" y1="110" x2="155" y2="290" stroke="#5D4037" stroke-width="4"/>
  <line x1="90" y1="200" x2="220" y2="200" stroke="#5D4037" stroke-width="4"/>

  <!-- Wall -->
  <rect x="0" y="300" width="512" height="100" fill="#FFF8E1" opacity="0.6"/>
  <rect x="0" y="300" width="512" height="5" fill="#D7CCC8" opacity="0.5"/>

  <!-- Floor -->
  <rect x="0" y="400" width="512" height="112" fill="#8D6E63" opacity="0.4"/>

  <!-- Bed/nightstand area -->
  <!-- Nightstand -->
  <rect x="280" y="350" width="80" height="50" rx="3" fill="#8D6E63"/>
  <rect x="278" y="347" width="84" height="6" rx="2" fill="#6D4C41"/>

  <!-- Legs -->
  <rect x="282" y="400" width="6" height="12" fill="#5D4037"/>
  <rect x="352" y="400" width="6" height="12" fill="#5D4037"/>

  <!-- Alarm clock on nightstand -->
  <circle cx="320" cy="335" r="18" fill="#FFD54F" stroke="#FF8F00" stroke-width="2"/>
  <circle cx="320" cy="335" r="14" fill="#FFF8E1"/>
  <!-- Clock face -->
  <line x1="320" y1="335" x2="320" y2="325" stroke="#333" stroke-width="2"/>
  <line x1="320" y1="335" x2="328" y2="335" stroke="#333" stroke-width="1.5"/>
  <!-- Clock legs -->
  <rect x="314" y="353" width="4" height="5" rx="1" fill="#8D6E63"/>
  <rect x="322" y="353" width="4" height="5" rx="1" fill="#8D6E63"/>
  <!-- Alarm bells -->
  <circle cx="310" cy="318" r="5" fill="#FFB300"/>
  <circle cx="330" cy="318" r="5" fill="#FFB300"/>

  <!-- Coffee cup -->
  <rect x="295" y="360" width="20" height="18" rx="3" fill="#FFFFFF" stroke="#BDBDBD" stroke-width="1.5"/>
  <path d="M315,363 Q322,365 322,372 Q322,378 315,378" stroke="#BDBDBD" stroke-width="1.5" fill="none"/>
  <!-- Coffee surface -->
  <rect x="297" y="362" width="16" height="4" rx="2" fill="#6D4C41" opacity="0.7"/>
  <!-- Steam -->
  <path d="M302,358 Q304,350 302,344" stroke="#BDBDBD" stroke-width="1.5" fill="none" opacity="0.5"/>
  <path d="M308,358 Q310,348 308,340" stroke="#BDBDBD" stroke-width="1.5" fill="none" opacity="0.5"/>

  <!-- Potted plant -->
  <!-- Pot -->
  <path d="M380,395 L370,360 L410,360 L400,395 Z" fill="#795548"/>
  <rect x="367" y="357" width="46" height="5" rx="2" fill="#6D4C41"/>
  <!-- Leaves -->
  <ellipse cx="390" cy="345" rx="8" ry="15" fill="#4CAF50" transform="rotate(-10,390,345)"/>
  <ellipse cx="380" cy="350" rx="6" ry="12" fill="#66BB6A" transform="rotate(-20,380,350)"/>
  <ellipse cx="400" cy="348" rx="7" ry="13" fill="#43A047" transform="rotate(15,400,348)"/>
  <ellipse cx="390" cy="335" rx="5" ry="10" fill="#81C784" transform="rotate(-5,390,335)"/>

  <!-- Small plant 2 on windowsill -->
  <path d="M125,295 L120,275 L130,275 Z" fill="#795548"/>
  <ellipse cx="125" cy="268" rx="5" ry="8" fill="#4CAF50"/>
  <ellipse cx="120" cy="270" rx="4" ry="7" fill="#66BB6A"/>
  <ellipse cx="130" cy="270" rx="4" ry="7" fill="#43A047"/>

  <!-- Open book on bed -->
  <rect x="60" y="380" width="40" height="28" rx="2" fill="#FFF9C4" transform="rotate(-5,80,394)"/>
  <line x1="80" y1="380" x2="80" y2="408" stroke="#BDBDBD" stroke-width="0.5" transform="rotate(-5,80,394)"/>

  <!-- Bed edge -->
  <rect x="30" y="370" width="200" height="15" rx="5" fill="#E8EAF6" opacity="0.7"/>
  <rect x="30" y="385" width="200" height="30" rx="3" fill="#C5CAE9" opacity="0.5"/>

  <!-- Title text -->
  <text x="256" y="470" text-anchor="middle" font-family="Arial, sans-serif" font-size="20" font-weight="bold" fill="#2E7D32" opacity="0.8">☀️ 早起養成完全指南</text>
  <text x="256" y="495" text-anchor="middle" font-family="Arial, sans-serif" font-size="12" fill="#558B2F" opacity="0.6">從賴床王變晨型人</text>

  <!-- Decorative leaves/spring around edges -->
  <!-- Bottom left leaves -->
  <ellipse cx="40" cy="460" rx="6" ry="14" fill="#66BB6A" opacity="0.5" transform="rotate(-30,40,460)"/>
  <ellipse cx="50" cy="465" rx="5" ry="12" fill="#81C784" opacity="0.4" transform="rotate(15,50,465)"/>

  <!-- Bottom right leaves -->
  <ellipse cx="470" cy="460" rx="6" ry="14" fill="#66BB6A" opacity="0.5" transform="rotate(30,470,460)"/>
  <ellipse cx="460" cy="465" rx="5" ry="12" fill="#81C784" opacity="0.4" transform="rotate(-15,460,465)"/>
</svg>

<svg xmlns="http://www.w3.org/2000/svg" width="512" height="512" viewBox="0 0 512 512">
  <defs>
    <linearGradient id="bg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#0a1628"/>
      <stop offset="100%" style="stop-color:#1a3a5c"/>
    </linearGradient>
    <linearGradient id="glow" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#00f5ff"/>
      <stop offset="100%" style="stop-color:#00ff88"/>
    </linearGradient>
    <filter id="neon">
      <feGaussianBlur stdDeviation="3" result="blur"/>
      <feMerge>
        <feMergeNode in="blur"/>
        <feMergeNode in="SourceGraphic"/>
      </feMerge>
    </filter>
  </defs>
  
  <!-- Background -->
  <rect width="512" height="512" fill="url(#bg)"/>
  
  <!-- Circuit pattern -->
  <g stroke="#1a4a6a" stroke-width="1" fill="none" opacity="0.3">
    <path d="M0 128 h128 v64 h64 v-64 h128"/>
    <path d="M512 384 h-128 v-64 h-64 v64 h-128"/>
    <path d="M128 0 v128 h64 v64"/>
    <path d="M384 512 v-128 h-64 v-64"/>
    <circle cx="192" cy="192" r="4" fill="#00f5ff"/>
    <circle cx="320" cy="320" r="4" fill="#00ff88"/>
  </g>
  
  <!-- Shield -->
  <path d="M256 80 L380 140 L380 280 C380 360 320 420 256 440 C192 420 132 360 132 280 L132 140 Z" 
        fill="none" stroke="url(#glow)" stroke-width="6" filter="url(#neon)"/>
  
  <!-- Lock icon -->
  <g transform="translate(256, 260)">
    <!-- Lock body -->
    <rect x="-35" y="0" width="70" height="60" rx="8" fill="#0a1628" stroke="url(#glow)" stroke-width="3" filter="url(#neon)"/>
    <!-- Lock shackle -->
    <path d="M-20 -30 L-20 -10 M-20 -30 Q-20 -50 0 -50 Q20 -50 20 -30 L20 -10" fill="none" stroke="url(#glow)" stroke-width="4" filter="url(#neon)"/>
    <!-- Keyhole -->
    <circle cx="0" cy="25" r="8" fill="#00f5ff" filter="url(#neon)"/>
    <rect x="-4" y="25" width="8" height="20" fill="#00f5ff" filter="url(#neon)"/>
  </g>
  
  <!-- Binary data streams -->
  <g fill="#00ff88" opacity="0.4" font-family="monospace" font-size="12">
    <text x="30" y="50">10110101</text>
    <text x="30" y="80">01001101</text>
    <text x="400" y="470">11010110</text>
    <text x="400" y="500">00111001</text>
  </g>
  
  <!-- Title -->
  <text x="256" y="480" text-anchor="middle" fill="#00f5ff" font-family="Arial, sans-serif" font-size="24" font-weight="bold" filter="url(#neon)">網路安全</text>
</svg>
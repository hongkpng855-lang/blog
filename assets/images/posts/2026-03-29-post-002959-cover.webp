<svg xmlns="http://www.w3.org/2000/svg" width="512" height="512" viewBox="0 0 512 512">
  <defs>
    <linearGradient id="bg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#fff8e7"/>
      <stop offset="100%" style="stop-color:#ffe4b5"/>
    </linearGradient>
    <linearGradient id="warm" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#ff7e5f"/>
      <stop offset="100%" style="stop-color:#feb47b"/>
    </linearGradient>
    <filter id="shadow">
      <feDropShadow dx="2" dy="4" stdDeviation="4" flood-color="#00000030"/>
    </filter>
  </defs>
  
  <!-- Background -->
  <rect width="512" height="512" fill="url(#bg)"/>
  
  <!-- Clock face -->
  <circle cx="256" cy="256" r="160" fill="white" stroke="#ff7e5f" stroke-width="8" filter="url(#shadow)"/>
  <circle cx="256" cy="256" r="140" fill="none" stroke="#ffe0d0" stroke-width="2"/>
  
  <!-- Hour markers -->
  <g fill="#ff7e5f">
    <circle cx="256" cy="126" r="8"/>
    <circle cx="346" cy="166" r="8"/>
    <circle cx="386" cy="256" r="8"/>
    <circle cx="346" cy="346" r="8"/>
    <circle cx="256" cy="386" r="8"/>
    <circle cx="166" cy="346" r="8"/>
    <circle cx="126" cy="256" r="8"/>
    <circle cx="166" cy="166" r="8"/>
  </g>
  
  <!-- Clock hands -->
  <line x1="256" y1="256" x2="256" y2="160" stroke="#333" stroke-width="6" stroke-linecap="round"/>
  <line x1="256" y1="256" x2="320" y2="200" stroke="#333" stroke-width="4" stroke-linecap="round"/>
  <circle cx="256" cy="256" r="12" fill="url(#warm)"/>
  
  <!-- Checkmark badge -->
  <circle cx="380" cy="140" r="50" fill="#4CAF50" filter="url(#shadow)"/>
  <path d="M355 140 L372 157 L405 124" fill="none" stroke="white" stroke-width="8" stroke-linecap="round" stroke-linejoin="round"/>
  
  <!-- Productivity icons -->
  <g transform="translate(60, 400)">
    <rect x="0" y="0" width="40" height="50" rx="4" fill="#ff7e5f" opacity="0.8"/>
    <line x1="10" y1="15" x2="30" y2="15" stroke="white" stroke-width="2"/>
    <line x1="10" y1="25" x2="30" y2="25" stroke="white" stroke-width="2"/>
    <line x1="10" y1="35" x2="25" y2="35" stroke="white" stroke-width="2"/>
  </g>
  
  <g transform="translate(400, 380)">
    <rect x="0" y="0" width="50" height="40" rx="4" fill="#ff7e5f" opacity="0.8"/>
    <circle cx="25" cy="20" r="10" fill="white"/>
    <path d="M25 15 L25 25 M20 20 L30 20" stroke="#ff7e5f" stroke-width="2"/>
  </g>
  
  <!-- Title -->
  <text x="256" y="480" text-anchor="middle" fill="#ff7e5f" font-family="Arial, sans-serif" font-size="28" font-weight="bold">時間管理</text>
</svg>
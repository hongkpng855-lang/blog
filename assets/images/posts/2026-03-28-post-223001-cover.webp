<svg xmlns="http://www.w3.org/2000/svg" width="512" height="512" viewBox="0 0 512 512">
  <defs>
    <linearGradient id="sky" x1="0%" y1="0%" x2="0%" y2="100%">
      <stop offset="0%" style="stop-color:#0a1628"/>
      <stop offset="50%" style="stop-color:#1a3a5c"/>
      <stop offset="100%" style="stop-color:#2d5a7b"/>
    </linearGradient>
    <linearGradient id="moon" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#fffde7"/>
      <stop offset="100%" style="stop-color:#fff9c4"/>
    </linearGradient>
    <filter id="glow">
      <feGaussianBlur stdDeviation="4" result="blur"/>
      <feMerge>
        <feMergeNode in="blur"/>
        <feMergeNode in="SourceGraphic"/>
      </feMerge>
    </filter>
    <filter id="soft">
      <feGaussianBlur stdDeviation="2"/>
    </filter>
  </defs>
  
  <!-- Night sky background -->
  <rect width="512" height="512" fill="url(#sky)"/>
  
  <!-- Stars -->
  <g fill="#ffffff" opacity="0.8">
    <circle cx="80" cy="60" r="2"/>
    <circle cx="150" cy="90" r="1.5"/>
    <circle cx="220" cy="40" r="2"/>
    <circle cx="300" cy="70" r="1.5"/>
    <circle cx="380" cy="50" r="2"/>
    <circle cx="450" cy="80" r="1.5"/>
    <circle cx="100" cy="150" r="1"/>
    <circle cx="420" cy="120" r="1.5"/>
    <circle cx="60" cy="200" r="1"/>
    <circle cx="480" cy="160" r="1"/>
    <circle cx="130" cy="250" r="1"/>
    <circle cx="400" cy="200" r="1"/>
  </g>
  
  <!-- Moon glow -->
  <circle cx="400" cy="120" r="60" fill="#fff9c4" opacity="0.1" filter="url(#soft)"/>
  
  <!-- Moon -->
  <circle cx="400" cy="120" r="40" fill="url(#moon)" filter="url(#glow)"/>
  <circle cx="390" cy="110" r="8" fill="#f5f5dc" opacity="0.3"/>
  <circle cx="410" cy="130" r="6" fill="#f5f5dc" opacity="0.2"/>
  
  <!-- Clouds (soft) -->
  <g fill="#1a4a6a" opacity="0.4" filter="url(#soft)">
    <ellipse cx="100" cy="180" rx="80" ry="30"/>
    <ellipse cx="400" cy="220" rx="100" ry="25"/>
    <ellipse cx="250" cy="300" rx="120" ry="35"/>
  </g>
  
  <!-- Zzz symbols -->
  <g fill="#7cb9e8" font-family="Arial, sans-serif" font-weight="bold" opacity="0.8">
    <text x="180" y="160" font-size="32" filter="url(#glow)">z</text>
    <text x="210" y="130" font-size="28" filter="url(#glow)">z</text>
    <text x="235" y="105" font-size="24" filter="url(#glow)">z</text>
  </g>
  
  <!-- Sleep icon (bed/moon combination) -->
  <g transform="translate(256, 350)">
    <!-- Bed shape -->
    <rect x="-80" y="0" width="160" height="80" rx="10" fill="#1a3a5c" stroke="#4a8eb8" stroke-width="3"/>
    <!-- Pillow -->
    <ellipse cx="-50" cy="25" rx="30" ry="20" fill="#2d5a7b"/>
    <!-- Person silhouette -->
    <ellipse cx="-50" cy="20" rx="15" ry="12" fill="#5a9bc8"/>
    <path d="M-35 32 Q0 32 35 32" stroke="#5a9bc8" stroke-width="20" stroke-linecap="round"/>
    <!-- Blanket wave -->
    <path d="M-60 60 Q-30 45 0 60 Q30 45 60 60" fill="none" stroke="#4a8eb8" stroke-width="4"/>
  </g>
  
  <!-- Title -->
  <text x="256" y="480" text-anchor="middle" fill="#7cb9e8" font-family="Arial, sans-serif" font-size="26" font-weight="bold" filter="url(#glow)">優質睡眠</text>
</svg>
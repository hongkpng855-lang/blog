<svg xmlns="http://www.w3.org/2000/svg" width="512" height="512" viewBox="0 0 512 512">
  <defs>
    <linearGradient id="bg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#f8f4e8"/>
      <stop offset="100%" style="stop-color:#e8dcc8"/>
    </linearGradient>
    <linearGradient id="warm" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#d4a574"/>
      <stop offset="100%" style="stop-color:#c49a6c"/>
    </linearGradient>
    <linearGradient id="plant" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#7cb342"/>
      <stop offset="100%" style="stop-color:#558b2f"/>
    </linearGradient>
  </defs>
  
  <!-- Background -->
  <rect width="512" height="512" fill="url(#bg)"/>
  
  <!-- Wooden floor -->
  <rect x="0" y="400" width="512" height="112" fill="#8d6e63"/>
  <g stroke="#6d4c41" stroke-width="1" opacity="0.5">
    <line x1="0" y1="420" x2="512" y2="420"/>
    <line x1="0" y1="450" x2="512" y2="450"/>
    <line x1="0" y1="480" x2="512" y2="480"/>
    <line x1="50" y1="400" x2="50" y2="512"/>
    <line x1="150" y1="400" x2="150" y2="512"/>
    <line x1="250" y1="400" x2="250" y2="512"/>
    <line x1="350" y1="400" x2="350" y2="512"/>
    <line x1="450" y1="400" x2="450" y2="512"/>
  </g>
  
  <!-- Shelf -->
  <rect x="60" y="120" width="180" height="15" fill="url(#warm)" rx="2"/>
  <rect x="60" y="120" width="15" height="280" fill="url(#warm)" rx="2"/>
  <rect x="225" y="120" width="15" height="280" fill="url(#warm)" rx="2"/>
  
  <!-- Books on shelf -->
  <rect x="80" y="85" width="25" height="35" fill="#5d4037" rx="2"/>
  <rect x="110" y="75" width="20" height="45" fill="#3e2723" rx="2"/>
  <rect x="135" y="80" width="30" height="40" fill="#4e342e" rx="2"/>
  <rect x="170" y="70" width="22" height="50" fill="#6d4c41" rx="2"/>
  <rect x="197" y="82" width="18" height="38" fill="#3e2723" rx="2"/>
  
  <!-- Storage box on shelf -->
  <rect x="80" y="160" width="60" height="50" fill="#ffcc80" rx="4"/>
  <rect x="150" y="155" width="70" height="55" fill="#a1887f" rx="4"/>
  
  <!-- Plant pot on shelf -->
  <ellipse cx="110" cy="260" rx="35" ry="10" fill="#8d6e63"/>
  <rect x="80" y="260" width="60" height="40" fill="#a1887f" rx="3"/>
  <ellipse cx="110" cy="260" rx="30" ry="8" fill="#5d4037"/>
  <!-- Plant leaves -->
  <ellipse cx="95" cy="235" rx="15" ry="25" fill="url(#plant)" transform="rotate(-20, 95, 235)"/>
  <ellipse cx="110" cy="230" rx="12" ry="28" fill="url(#plant)"/>
  <ellipse cx="125" cy="235" rx="15" ry="25" fill="url(#plant)" transform="rotate(20, 125, 235)"/>
  
  <!-- Sofa -->
  <rect x="280" y="320" width="180" height="80" fill="#8d6e63" rx="10"/>
  <rect x="280" y="280" width="180" height="50" fill="#a1887f" rx="8"/>
  <rect x="270" y="290" width="20" height="100" fill="#795548" rx="5"/>
  <rect x="450" y="290" width="20" height="100" fill="#795548" rx="5"/>
  <!-- Cushions -->
  <ellipse cx="320" cy="350" rx="30" ry="20" fill="#ffcc80"/>
  <ellipse cx="420" cy="350" rx="30" ry="20" fill="#d4a574"/>
  
  <!-- Coffee table -->
  <rect x="310" y="420" width="120" height="8" fill="#5d4037" rx="2"/>
  <rect x="320" y="428" width="10" height="40" fill="#5d4037"/>
  <rect x="410" y="428" width="10" height="40" fill="#5d4037"/>
  
  <!-- Items on table -->
  <rect x="340" y="405" width="30" height="15" fill="#fff8e1" rx="2"/>
  <rect x="380" y="400" width="20" height="20" fill="#ffe082" rx="2"/>
  
  <!-- Window -->
  <rect x="320" y="50" width="150" height="180" fill="#87ceeb" stroke="#a1887f" stroke-width="8" rx="5"/>
  <line x1="395" y1="50" x2="395" y2="230" stroke="#a1887f" stroke-width="6"/>
  <line x1="320" y1="140" x2="470" y2="140" stroke="#a1887f" stroke-width="6"/>
  
  <!-- Curtains -->
  <path d="M310 40 Q300 140 315 230" fill="none" stroke="#ffcc80" stroke-width="15" opacity="0.7"/>
  <path d="M480 40 Q490 140 475 230" fill="none" stroke="#ffcc80" stroke-width="15" opacity="0.7"/>
  
  <!-- Lamp -->
  <rect x="250" y="200" width="8" height="100" fill="#bcaaa4"/>
  <ellipse cx="254" cy="195" rx="40" ry="20" fill="#ffeb3b" opacity="0.3"/>
  <path d="M220 195 L254 180 L288 195 Z" fill="#fff8e1"/>
  
  <!-- Title -->
  <text x="256" y="500" text-anchor="middle" fill="#5d4037" font-family="Arial, sans-serif" font-size="22" font-weight="bold">居家生活</text>
</svg>